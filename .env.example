# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Reddit API (https://www.reddit.com/prefs/apps → create app → script)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FinancialAdvisorBot/1.0 by /u/your_username

# Gmail (use an App Password, not your real password)
# Enable 2FA → Google Account → Security → App Passwords → create one
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
RECIPIENT_EMAIL=your_email@gmail.com

# Timezone (e.g. America/Toronto, America/New_York, Europe/Paris)
TIMEZONE=America/Toronto

# Schedule times (24h format, in your timezone)
MORNING_HOUR=7
LUNCH_HOUR=12
EVENING_HOUR=18
